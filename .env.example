# AgentFlow 环境变量模板
# 复制此文件为 .env 并填入你的配置
# cp .env.example .env

# ============================================
# LLM 配置（必须）
# ============================================
# 主力 LLM Provider: deepseek / openai / dashscope
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat

# DeepSeek API Key（推荐，便宜，国内直连）
DEEPSEEK_API_KEY=***
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI API Key（可选，备用）
# OPENAI_API_KEY=***

# DashScope / 通义千问（可选）
# DASHSCOPE_API_KEY=***

# ============================================
# HuggingFace 加速（国内必须）
# ============================================
# BGE 模型下载镜像，国内必设，否则连不上 huggingface.co
HF_ENDPOINT=https://hf-mirror.com

# ============================================
# 数据库配置
# ============================================
# 数据库类型: sqlite / postgresql
DB_TYPE=sqlite
SQLITE_PATH=./data/sample.db

# PostgreSQL（DB_TYPE=postgresql 时使用）
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=***
# PG_DATABASE=agentflow

# ============================================
# 向量库配置
# ============================================
CHROMA_PERSIST_DIR=./chroma_data

# ============================================
# 服务配置
# ============================================
# FastAPI 端口
FASTAPI_PORT=8000

# Streamlit 端口
STREAMLIT_PORT=8501

# 上传文件目录
UPLOAD_DIR=./uploads

# 最大上传大小（MB）
MAX_UPLOAD_SIZE_MB=50
