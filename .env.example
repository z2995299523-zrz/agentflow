# AgentFlow 环境变量配置
# 复制此文件为 .env 并填入你的配置

# ============================================
# LLM 配置（支持 OpenAI 及国内模型）
# ============================================
# API 地址：不填=OpenAI官方，填 https://api.deepseek.com/v1 用 DeepSeek
LLM_API_BASE=
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-3.5-turbo

# Embedding 模型（向量化用）
EMBEDDING_MODEL=text-embedding-3-small

# ============================================
# 数据库配置
# ============================================
DB_TYPE=sqlite
SQLITE_PATH=./data/sample.db

# PostgreSQL（可选）
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=agentflow

# ============================================
# 向量库配置
# ============================================
CHROMA_PERSIST_DIR=./chroma_data

# ============================================
# 服务配置
# ============================================
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
STREAMLIT_PORT=8501

# 上传文件
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
